# Copy this file to .env.local and fill in real values.

# OpenRouter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openrouter/auto

# Optional — branding shown in the OpenRouter dashboard
OPENROUTER_APP_NAME=AutoReport
OPENROUTER_SITE_URL=http://localhost:3000

# Keep Puppeteer's Chromium download inside the repo to avoid
# OneDrive / antivirus issues on Windows home directories.
PUPPETEER_CACHE_DIR=./.cache/puppeteer
